<div class="form-wrapper" data-qty="<%= qty %>">
  <div class="form-container">
    <div class="left">
      <a href="#" onclick="history.back(); return false;" class="btn-back">
        <i class="bi bi-chevron-left"></i>
        <span>Back</span>
      </a>
      <div class="left-detail">
        <h1>Detail Pemesanan</h1>
        <p>
          Lengkapi Daftar Diri dan Detail Pemesanan Anda untuk meminjam produk
          terbaik dari kami!
        </p>
      </div>
    </div>

    <div class="right">
      <div class="logo">Lab<span>Ly</span></div>

      <form action="/submit-data" method="post" id="loan-order-form">
        <input type="hidden" name="action_type" value="<%= action %>" />
        <input type="hidden" name="product_id" value="<%= product.id %>" />
        <input type="hidden" name="extend_order_id" value="<%= typeof extendOrderId !== 'undefined' ? extendOrderId : '' %>" />

        <div class="form-section">
          <p>Product Detail</p>

          <!-- Nama Produk -->
          <div class="grid">
            <input type="text" value="<%= product.name %>" readonly />
          </div>

          <!-- Qty & Harga -->
          <div class="grid">
            <input type="number" id="qty" value="<%= qty %>" readonly />
            <input
              type="text"
              id="price"
              data-price="<%= product.price %>"
              value="Rp<%= product.price.toLocaleString() %> / Item - Total: Rp<%= priceTotal.toLocaleString() %>"
              readonly
            />
          </div>

          <!-- Tambahkan ini: -->
          <input
            type="hidden"
            id="priceRaw"
            name="price"
            value="<%= product.price %>"
          />
          <input type="hidden" id="qtyRaw" name="quantity" value="<%= qty %>" />

          <!-- Tanggal -->
          <div class="grid">
            <input 
              type="date" 
              id="borrowDate" 
              name="borrow_date" 
              value="<%= typeof borrowDate !== 'undefined' ? borrowDate : '' %>"
              <%= action === 'extend' ? 'readonly' : '' %>
              style="<%= action === 'extend' ? 'background: #f5f7ff; color: #555; cursor: not-allowed;' : '' %>"
              required 
            />
            <input type="date" id="returnDate" name="return_date" required />
          </div>

          <div class="grid-2">
            <input
              type="text"
              id="allTotal"
              name="all_total"
              placeholder="Subtotal"
              readonly
            />
            <input
              type="hidden"
              id="allTotalRaw"
              name="all_total_raw"
              value="0"
            />
          </div>
        </div>

        <div class="form-section">
          <p>User Data</p>

          <div class="grid">
              <input type="text" value="<%= user.username %>" readonly/>
              <input type="text" name="phone" value="<%= user.phone %>" readonly/>
          </div>

          <div class="grid-2">
              <input type="text" name="address" value="<%= user.address %>" readonly/>
          </div>
        </div>

        <button class="btn-next">
          Selanjutnya <span><i class="bi bi-arrow-right-circle-fill"></i></span>
        </button>
      </form>
    </div>
  </div>
</div>
