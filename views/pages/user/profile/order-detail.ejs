<%
function formatTanggal(tanggal) {
  const bulan = [
    "January","February","March","April",
    "May","June","July","August",
    "September","October","November","December"
  ];
  const d = new Date(tanggal);
  return `${d.getDate()} ${bulan[d.getMonth()]} ${d.getFullYear()}`;
}

const status = (order.status || '').toString().toLowerCase();
const paymentMethodRaw = (order.payment_method || '').toString();
let paymentStatus = paymentMethodRaw ? 'PAID' : 'UNPAID';

if (status === 'completed') {
  paymentStatus = 'RETURNED';
} else if (status === 'overdue') {
  paymentStatus = 'OVERDUE';
} else if (status === 'in use') {
  paymentStatus = paymentMethodRaw ? 'PAID' : 'UNPAID';
} else if (status === 'pending') {
  paymentStatus = paymentMethodRaw ? 'PAID' : 'UNPAID';
}

const paymentMethod = paymentMethodRaw.toLowerCase() === 'e-wallet'
  ? `ewallet - (${order.ewallet_provider || 'Unknown'})`
  : paymentMethodRaw || 'Unknown';

const timelineSteps = [
  { label: 'Payment Verified' },
  { label: 'Waiting for Approval' },
  { label: 'Item Picked Up' },
  { label: 'Item Returned' }
];

let completedCount = 1;

if (status === 'pending') {
    completedCount = 2;
} else if (status === 'in use') {
    completedCount = 3;
} else if (status === 'overdue') {
    completedCount = 3;
} else if (status === 'completed' || status === 'returned') {
    completedCount = 4;
}
%>

<!-- ===== TOP BAR ===== -->
<div class="top-bar">
    <a href="/order-user" class="btn-back">
      <i class="bi bi-arrow-left"></i>
      <span>Back to Order List</span>
    </a>
    <div class="top-bar-title">
        <h1>Order Detail</h1>
        <span class="order-id-badge">#TRX-<%= order.id %></span>
    </div>
</div>

<!-- ===== MAIN GRID ===== -->
<div class="detail-grid">

  <!-- Card: Informasi Alat -->
  <div class="card card-tool-info">
    <div class="card-header">
      <h2>Tool Information</h2>
    </div>
    <div class="tool-info-body">
      <div class="tool-img-wrap">
        <img
          src="<%= order.product_image ? '/uploads/' + order.product_image : '/Assets/default.png' %>"
          alt="<%= order.product_name %>"
        />
      </div>
      <div class="tool-meta">
        <h3 class="tool-name"><%= order.product_name %></h3>
        <div class="tool-meta-row">
          <span class="meta-label">Tool Code</span>
          <span class="meta-value primary">LAB-MIC-<%= String(order.id_products).padStart(3, '0') %></span>
        </div>
        <div class="tool-meta-row">
          <span class="meta-label">Category</span>
          <span class="meta-value"><%= order.category_name %></span>
        </div>
        <div class="tool-meta-row">
          <span class="meta-label">Condition</span>
          <span class="badge-kondisi"><%= order.kondisi %></span>
        </div>
      </div>
    </div>
  </div>

  <!-- Card: Ringkasan Peminjaman -->
  <div class="card card-summary">
    <div class="card-header between">
      <h2>Loan Summery</h2>
    </div>
    <div class="summary-grid">
      <div class="summary-item">
        <i class="bi bi-archive-fill"></i>
        <div>
          <p class="summary-label">Quantity Borrowed</p>
          <p class="summary-value"><%= order.qty %> Unit</p>
        </div>
      </div>
      <div class="summary-item">
        <i class="bi bi-calendar-check-fill"></i>
        <div>
          <p class="summary-label">Duration of Borrowing</p>
          <p class="summary-value"><%= order.tgl_pinjam.replace(/-/g, '/') %> - <%= order.tgl_kembali.replace(/-/g, '/') %></p>
        </div>
      </div>
      <div class="summary-item">
        <i class="bi bi-currency-exchange"></i>
        <div>
          <p class="summary-label">Cost of Borrowing</p>
          <p class="summary-value">Rp <%= Number(order.product_price).toLocaleString('id-ID') %></p>
        </div>
      </div>
      <div class="summary-item">
        <i class="bi bi-currency-exchange"></i>
        <div>
          <p class="summary-label">Total Cost</p>
          <p class="summary-value accent">Rp <%= Number(order.price).toLocaleString('id-ID') %></p>
        </div>
      </div>
    </div>
    <div class="card-action">
        <div class="status-barang-wrap">
            <span class="status-barang-label">Item Status</span>
            <span class="status-chip
                <%= status === 'completed' ? 'chip-complete'
                    : status === 'overdue'   ? 'chip-overdue'
                    : status === 'pending'   ? 'chip-paid'
                    : 'chip-active' %>">
                <% if (status === 'completed') { %><i class="bi bi-check-circle-fill"></i> Returned
                <% } else if (status === 'overdue') { %><i class="bi bi-exclamation-circle-fill"></i> Overdue
                <% } else if (status === 'pending') { %><i class="bi bi-clock-fill"></i> Paid
                <% } else { %><i class="bi bi-clock-history"></i> In Use
                <% } %>
            </span>
        </div>
      <%
        const hasPendingExtend = Number(order.pending_extend) > 0;

        const disableExtend =
            status === "completed" ||
            hasPendingExtend;
        %>

<% if (hasPendingExtend) { %>

<a href="#" class="btn-tambah btn-disabled" style="pointer-events:none;">
    <i class="bi bi-hourglass-split"></i>
    Extension Request Pending
</a>

<% } else if (status === "completed") { %>

<a href="#" class="btn-tambah btn-disabled" style="pointer-events:none;">
    <i class="bi bi-check-circle"></i>
    Borrowing Completed
</a>

<% } else { %>

<a href="/form?action=extend&product_id=<%= order.id_products %>&qty=<%= order.qty %>&borrow_date=<%= order.tgl_kembali %>&extend_order_id=<%= order.id %>" class="btn-tambah">
    <i class="bi bi-plus-circle"></i>
    Add Borrowing Duration
</a>

<% } %>
    </div>
  </div>

  <!-- Card: Timeline + Pembayaran + Pengembalian (3 kolom bawah) -->
  <div class="middle-row">
    <!-- Card: Informasi Peminjam -->
    <div class="card card-borrower">
      <div class="card-header">
        <h2>Borrower Data</h2>
      </div>
      <div class="borrower-list">
        <div class="borrower-row">
          <span class="borrower-label"><i class="bi bi-person-fill"></i>Name</span>
          <span class="borrower-value"><%= order.username %></span>
        </div>
        <div class="borrower-row">
          <span class="borrower-label"><i class="bi bi-envelope-fill"></i>Email</span>
          <span class="borrower-value"><%= order.email %></span>
        </div>
        <div class="borrower-row">
          <span class="borrower-label"><i class="bi bi-telephone-fill"></i>Phone Number</span>
          <span class="borrower-value"><%= order.phone || '-' %></span>
        </div>
        <div class="borrower-row address-row">
          <span class="borrower-label"><i class="bi bi-geo-alt-fill"></i>Address</span>
          <span class="borrower-value"><%= order.address || '-' %></span>
        </div>
      </div>
    </div>

    <!-- Timeline -->
    <div class="card card-timeline">
      <div class="card-header">
        <h2>Loan Timeline</h2>
      </div>
      <div class="timeline">
        <% timelineSteps.forEach(function(step, idx) {
          const done = idx < completedCount; %>
          <div class="tl-step">
            <div class="tl-dot-wrap">
              <div class="tl-dot <%= done ? 'done' : '' %>">
                <% if (done) { %><i class="bi bi-check-lg"></i><% } %>
              </div>
              <% if (idx < timelineSteps.length - 1) { %>
                <div class="tl-line <%= (idx + 2) <= completedCount ? 'done' : '' %>"></div>
              <% } %>
            </div>
            <div class="tl-label <%= done ? 'label-done' : 'label-pending' %>">
              <%= step.label %>
              <% if (done) { %>
                <% if (idx === 0) { %>
                  <span class="tl-badge paid">Paid</span>
                <% } else if (idx === 2) { %>
                  <% if (status === 'overdue') { %>
                    <span class="tl-badge overdue">Overdue</span>
                  <% } else { %>
                    <span class="tl-badge active">In Use</span>
                  <% } %>
                <% } %>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
    </div>

    <!-- Pembayaran -->
    <div class="card card-payment">
      <div class="card-header">
        <h2>Payment Information</h2>
      </div>
      <div class="payment-list">
        <div class="payment-row">
          <span class="payment-label">Status</span>
          <span class="badge-paid"><%= paymentStatus %></span>
        </div>
        <div class="payment-row">
          <span class="payment-label">Method</span>
          <span class="payment-val"><%= paymentMethod %></span>
        </div>
        <div class="payment-row">
          <span class="payment-label">Date</span>
          <span class="payment-val"><%= formatTanggal(order.tgl_pinjam) %></span>
        </div>
        <div class="payment-row">
          <span class="payment-label">Transaction Number</span>
          <span class="payment-val mono">TRX-<%= order.id %></span>
        </div>
      </div>
      <a href="/receipt/<%= order.id %>" class="btn-proof">
    <i class="bi bi-receipt"></i>
    Print Payment Proof
</a>
    </div>
  </div>

    <!-- Return Information -->
    <div class="card card-return">
      <div class="card-header">
        <h2>Return Information</h2>
      </div>

      <% if (status === 'completed') { %>
        <div class="return-box success">
          <div class="return-icon">
            <i class="bi bi-check-circle-fill"></i>
          </div>
          <div class="return-content">
            <h3>Item Successfully Returned</h3>
            <p>
              Your borrowed item has been returned safely.
              Thank you for trusting our laboratory equipment lending service.
            </p>
          </div>
        </div>
      <% } else if (status === 'overdue') { %>
        <div class="return-box overdue">
          <div class="return-icon">
            <i class="bi bi-exclamation-triangle-fill"></i>
          </div>
          <div class="return-content">
            <h3>Return Overdue</h3>
            <p>
              The return deadline has passed.
              Please return the borrowed item as soon as possible to avoid additional penalties.
            </p>
          </div>
        </div>
      <% } else if (status === 'in use') { %>
        <div class="return-box active">
          <div class="return-icon">
            <i class="bi bi-clock-history"></i>
          </div>
          <div class="return-content">
            <h3>Borrowing in Progress</h3>
            <p>
              Please return the borrowed item on or before
              <strong><%= formatTanggal(order.tgl_kembali) %></strong>.
              Ensure the item is returned in good condition.
            </p>
          </div>
        </div>
      <% } else { %>
        <div class="return-box pending">
          <div class="return-icon">
            <i class="bi bi-hourglass-split"></i>
          </div>
          <div class="return-content">
            <h3>Waiting for Approval</h3>
            <p>
              Your borrowing request is currently being reviewed.
              Return information will be available after your request has been approved.
            </p>
          </div>
        </div>
      <% } %>
    </div>

</div>