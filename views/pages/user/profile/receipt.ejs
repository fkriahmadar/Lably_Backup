<%
function formatTanggal(tanggal){
    const bulan = [
        "January","February","March","April",
        "May","June","July","August",
        "September","October","November","December"
    ];

    const d = new Date(tanggal);

    return `${d.getDate()} ${bulan[d.getMonth()]} ${d.getFullYear()}`;
}

const paymentMethod =
    (order.payment_method || "").toLowerCase() === "e-wallet"
        ? `E-Wallet (${order.ewallet_provider || "Unknown"})`
        : (order.payment_method || "Unknown");

const today = formatTanggal(new Date());
%>

<div class="receipt-page">

    <div class="receipt-navbar">
        <a href="/order-detail/<%= order.id %>" class="btn-back">
            <i class="bi bi-arrow-left"></i>
            Back to Order Detail
        </a>

        <button class="btn-print" onclick="window.print()">
            <i class="bi bi-printer"></i>
            Print Receipt
        </button>
    </div>

    <div class="receipt">

        <div class="receipt-top"></div>

        <div class="receipt-header">

            <h1 class="receipt-title">
                <span class="lab">Lab</span><span class="ly">Ly</span>
            </h1>

            <p class="receipt-subtitle">
                Laboratory Equipment Borrowing Receipt
            </p>

            <div class="receipt-number">
                Receipt #TRX-<%= order.id %>
            </div>

        </div>

        <div class="receipt-divider"></div>

        <div class="receipt-user">
            <span>Borrower</span>
            <strong><%= order.username %></strong>
        </div>

        <div class="receipt-user">
            <span>Transaction Number</span>
            <strong>TRX-<%= order.id %></strong>
        </div>

        <div class="receipt-user">
            <span>Receipt Date</span>
            <strong><%= today %></strong>
        </div>

        <div class="receipt-user">
            <span>Loan Period</span>
            <strong>
                <%= formatTanggal(order.tgl_pinjam) %> -
                <%= formatTanggal(order.tgl_kembali) %>
            </strong>
        </div>

        <div class="receipt-divider"></div>

<table class="receipt-table">
    <thead>
        <tr>
            <th>Qty</th>
            <th>Equipment</th>
            <th>Unit Price</th>
        </tr>
    </thead>

    <tbody>
        <tr>
            <td><%= order.qty %></td>
            <td><%= order.product_name %></td>
            <td>
                Rp <%= Number(order.product_price).toLocaleString("id-ID") %>
            </td>
        </tr>
    </tbody>
</table>

<div class="receipt-divider"></div>

<div class="receipt-summary">

    <div class="summary-row">
        <span>Item Count</span>
        <strong><%= order.qty %> Item</strong>
    </div>

    <div class="summary-row">
        <span>Subtotal</span>
        <strong>
            Rp <%= Number(order.price).toLocaleString("id-ID") %>
        </strong>
    </div>

    <div class="summary-row total">
        <span>Total Cost</span>
        <strong>
            Rp <%= Number(order.price).toLocaleString("id-ID") %>
        </strong>
    </div>

</div>

<div class="receipt-divider"></div>

<div class="receipt-motto">
    <p>
        "Empowering every discovery, equipping every future."
    </p>
</div>

<div class="receipt-divider"></div>

<div class="receipt-user">
    <span>Payment Method</span>
    <strong><%= paymentMethod %></strong>
</div>

<div class="receipt-user">
    <span>Payment Status</span>
    <strong class="status-paid">
        PAID
    </strong>
</div>

<div class="receipt-divider"></div>
<div class="receipt-footer">
    <h3>Thank You!</h3>

    <p>
        Thank you for choosing LabLy. We appreciate your trust and hope our laboratory equipment supports your learning, research, and innovation.
    </p>
</div>

<div class="receipt-divider"></div>

<div class="barcode-area">
    <svg id="barcode"></svg>

    <p class="barcode-id">
        TRX-<%= order.id %>
    </p>
</div>

<div class="receipt-note">
    This receipt is automatically generated by LabLy and serves as valid proof of payment.
</div>

<div class="receipt-bottom"></div>

</div>

</div>

<script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.6/dist/JsBarcode.all.min.js"></script>

<script>
JsBarcode("#barcode", "TRX-<%= order.id %>", {
    format: "CODE128",
    lineColor: "#1D4F91",
    width: 2,
    height: 70,
    displayValue: false,
    margin: 0
});
</script>