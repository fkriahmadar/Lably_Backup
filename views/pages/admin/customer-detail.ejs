<!-- customer-detail.ejs -->

<div class="profile-content">
  <!-- HEADER -->
  <div class="profile-header">
    <a href="/customer" class="btn-back"><i class="bi bi-arrow-left"></i>Back</a>
    <h1>Customer Details</h1>
    <p>Customer Information Details</p>
  </div>

  <div class="profile-body">
    <!-- KIRI: Informasi Pribadi (readonly) -->
    <div class="profile-card info-card">
      <div class="card-title">
        <h2>User Information</h2>
        <p>User Information Details</p>
      </div>

      <div class="form-group">
        <label>Full Name</label>
        <input type="text" value="<%= user.username %>" readonly />
      </div>

      <div class="form-group">
        <label>Email</label>
        <input type="email" value="<%= user.email %>" readonly />
      </div>

      <div class="form-group">
        <label>Phone Number</label>
        <input type="text" value="<%= user.phone || '-' %>" readonly />
      </div>

      <div class="form-group">
        <label>Account Status</label>
        <input type="text" value="<%= user.status %>" readonly />
      </div>

      <div class="form-group">
        <label>Join Date</label>
        <input type="text" value="<%= user.created_at ? new Date(user.created_at).toLocaleDateString('id-ID') : '-' %>" readonly />
      </div>
    </div>

    <!-- KANAN: Foto KTP -->
    <div class="profile-side">
      <div class="profile-card avatar-card">
        <% if(user.ktp_image) { %>
          <img src="<%= user.ktp_image %>" alt="Foto KTP" class="ktp-preview-img" />
          <p class="ktp-label">Identity Card</p>
        <% } else { %>
          <div class="ktp-empty">
            <i class="bi bi-person-vcard"></i>
            <p>No Identity Card Yet</p>
          </div>
        <% } %>
      </div>

      <!-- Status KTP -->
      <div class="profile-card security-card">
        <div class="card-title">
          <h2>Verified Status</h2>
          <p>Identity Card Status</p>
        </div>
        <div class="ktp-status-info">
          <% if(user.ktp_status === 'verified') { %>
            <span class="ktp-badge verified"><i class="bi bi-check-circle"></i> Verified</span>
          <% } else if(user.ktp_status === 'pending') { %>
            <span class="ktp-badge pending"><i class="bi bi-clock"></i> Pending</span>
          <% } else if(user.ktp_status === 'rejected') { %>
            <span class="ktp-badge rejected"><i class="bi bi-x-circle"></i> Rejected</span>
          <% } else { %>
            <span class="ktp-badge unverified"><i class="bi bi-dash-circle"></i> Unverified</span>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <!-- APPROVAL -->
  <div class="profile-card help-card
    <% if(user.ktp_status === 'verified') { %>verified
    <% } else if(user.ktp_status === 'rejected') { %>rejected
    <% } else if(user.ktp_status === 'pending') { %>pending<% } %>">

    <div class="help-icon">
      <% if(user.ktp_status === 'verified') { %>
        <i class="bi bi-check-circle"></i>
      <% } else if(user.ktp_status === 'rejected') { %>
        <i class="bi bi-x-circle"></i>
      <% } else { %>
        <i class="bi bi-exclamation-circle"></i>
      <% } %>
    </div>

    <div class="help-text">
      <% if(user.ktp_status === 'verified') { %>
        <h4>Identity Verified</h4>
        <p>Customer has been successfully verified.</p>
      <% } else if(user.ktp_status === 'rejected') { %>
        <h4>Rejected</h4>
        <p>Customer's identity card has been rejected.</p>
      <% } else if(user.ktp_status === 'pending') { %>
        <h4>Pending</h4>
        <p>Customer has uploaded an identity card and is waiting for admin verification.</p>
      <% } else { %>
        <h4>Unverified</h4>
        <p>Customer has not uploaded an identity card.</p>
      <% } %>
    </div>

    <!-- Tombol approval hanya muncul saat pending -->
    <% if(user.ktp_status === 'pending') { %>
      <div class="approval-actions">
        <form action="/customer/<%= user.id %>/approve-ktp" method="POST" style="display:inline">
          <button type="submit" class="btn-approve">
            <i class="bi bi-check-lg"></i> Approve
          </button>
        </form>
        <form action="/customer/<%= user.id %>/reject-ktp" method="POST" style="display:inline">
          <button type="submit" class="btn-reject">
            <i class="bi bi-x-lg"></i> Reject
          </button>
        </form>
      </div>
    <% } %>
  </div>
</div>