<div class="logo">Lab<span>Ly</span></div>
<div class="left-menu">

  <% if (user.ktp_status === 'verified') { %>
    <div class="menu dashboard <%= currentPage === '/dashboard-customer' ? 'active' : '' %>">
      <a href="/dashboard-customer">
        <i class="bi bi-house-door"></i>
        <span>Dashboard</span>
      </a>
    </div>
    <div class="menu orders <%= currentPage === '/order-user' ? 'active' : '' %>">
      <a href="/order-user">
        <i class="bi bi-cart"></i>
        <span>My Orders</span>
      </a>
    </div>
  <% } %>

  <div class="menu profile <%= currentPage === '/profile-customer' ? 'active' : '' %>">
    <a href="/profile-customer">
      <i class="bi bi-person"></i>
      <span>Profile</span>
    </a>
  </div>

  <div class="menu home">
    <a href="/">
      <i class="bi bi-arrow-left-circle"></i>
      <span>Back to Home</span>
    </a>
  </div>
</div>

<div class="logout">
  <a href="/logout">
    <i class="bi bi-box-arrow-right"></i>
    <span>Log Out</span>
  </a>
</div>